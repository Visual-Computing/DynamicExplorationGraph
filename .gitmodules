[submodule "external/fmt"]
	path = cpp/external/fmt
	url = https://github.com/fmtlib/fmt
	branch = 7.1.3
[submodule "external/robin-map"]
	path = cpp/external/robin-map
	url = https://github.com/Tessil/robin-map.git
    branch = 0.6.3
[submodule "cpp/python-bindings/external/pybind11"]
	path = cpp/python-bindings/external/pybind11
	url = git@github.com:pybind/pybind11.git
	branch = stable
